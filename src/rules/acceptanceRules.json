{
  "base_rules": [
    {
      "category": "页面验收",
      "items": [
        "桌面端和移动端均正常显示",
        "移动端不能横向溢出",
        "页面加载时间在 3 秒以内",
        "所有图片正常加载",
        "所有链接可点击"
      ]
    },
    {
      "category": "交互验收",
      "items": [
        "用户操作后必须有明确反馈",
        "加载中必须有 loading 或 skeleton",
        "空数据必须有 empty state",
        "表单提交中按钮进入 loading，避免重复提交",
        "提交成功后显示 toast 或结果页",
        "提交失败后显示明确错误提示"
      ]
    },
    {
      "category": "异常状态验收",
      "items": [
        "异常状态不能导致页面白屏",
        "网络断开时有友好提示",
        "接口超时时有重试机制",
        "404 页面有返回首页入口",
        "500 错误有友好提示"
      ]
    },
    {
      "category": "代码验收",
      "items": [
        "控制台无明显报错",
        "无未使用的变量和导入",
        "无硬编码的测试数据"
      ]
    }
  ],
  "backend_rules": [
    {
      "category": "后端验收",
      "items": [
        "所有接口有统一错误处理",
        "所有请求有 request_id",
        "关键操作有日志记录",
        "敏感操作有审计日志",
        "数据库操作有事务保护"
      ]
    },
    {
      "category": "日志验收",
      "items": [
        "错误日志包含足够排查信息",
        "日志有统一格式",
        "日志级别正确使用",
        "敏感信息不写入日志"
      ]
    }
  ],
  "payment_rules": [
    {
      "category": "支付验收",
      "items": [
        "不能只靠前端跳转判断支付成功",
        "必须以后端回调或订单查询确认状态",
        "支付金额必须后端计算",
        "订单状态必须有幂等处理",
        "支付失败有明确提示",
        "退款流程正常"
      ]
    }
  ],
  "auth_rules": [
    {
      "category": "权限验收",
      "items": [
        "权限校验不能只靠前端",
        "所有敏感接口有鉴权",
        "Token 过期有刷新机制",
        "未登录有跳转登录页",
        "无权限有友好提示"
      ]
    }
  ],
  "definition_of_done": [
    "所有功能按需求实现",
    "所有验收用例通过",
    "代码 Review 通过",
    "无 P0/P1 Bug",
    "文档更新完成",
    "部署脚本准备就绪"
  ]
}
